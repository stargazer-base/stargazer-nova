// 接続先の設定
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 動画テーブルの定義
model Video {
  id           String   @id @default(uuid())
  title        String
  url          String   @unique
  thumbnailUrl String?  // ?は空（null）を許容する設定
  oshiName     String
  tags         String[] // ★PostgreSQLの特権である「配列型」がそのまま使えます！
  duration     String
  publishedAt  String
}